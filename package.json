{
  "name": "studyspace",
  "version": "0.1.0",
  "private": true,
  "description": "Aesthetic productivity dashboard — GitHub Pages frontend + Cloudflare Worker backend",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "dev:frontend": "npx serve . --listen 3000 --no-clipboard",
    "gas:login": "clasp login",
    "gas:push": "clasp push --rootDir gas",
    "gas:deploy": "clasp deploy --rootDir gas"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "wrangler": "^3.0.0"
  }
}
